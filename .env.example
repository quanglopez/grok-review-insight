# MiMo Review Audit — copy to `.env` and fill in real values.
# Never commit `.env` (see `.gitignore`).

# --- Supabase (client / Vite) ---
# Project URL: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable (anon) key — format often starts with sb_publishable_
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# --- Supabase (server / TanStack Start server functions) ---
# Same project URL as VITE_SUPABASE_URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Same publishable key as VITE_SUPABASE_PUBLISHABLE_KEY (used by auth middleware + getClaims)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# --- MiMo (server-only; never expose to the browser) ---
# Required for runAnalysis (report, recommendations, reply templates)
# Get from Xiaomi MiMo API / your provider dashboard
MIMO_API_KEY=your_mimo_api_key_here

# --- Optional (not used by current app routes; only if you import supabaseAdmin) ---
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
